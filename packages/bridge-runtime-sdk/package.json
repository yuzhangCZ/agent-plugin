{
  "name": "@agent-plugin/bridge-runtime-sdk",
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/build-package.mjs",
    "build:dev": "BRIDGE_RUNTIME_SDK_MINIFY=0 node ./scripts/build-package.mjs",
    "typecheck": "pnpm exec tsc -p ./tsconfig.json",
    "pack:check": "node ./scripts/check-pack.mjs",
    "prepack": "node ./scripts/prepare-publish-manifest.mjs",
    "prepublishOnly": "pnpm run verify:release",
    "postpack": "node ./scripts/restore-publish-manifest.mjs",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "verify:core": "pnpm run build && pnpm run typecheck && pnpm test && pnpm run pack:check",
    "verify:release": "pnpm run verify:core"
  },
  "devDependencies": {
    "@agent-plugin/gateway-client": "workspace:*",
    "@agent-plugin/gateway-schema": "workspace:*",
    "@types/node": "^22.10.2",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
