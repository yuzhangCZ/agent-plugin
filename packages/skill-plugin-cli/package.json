{
  "name": "@wecode/skill-plugin-cli",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "skill-plugin-cli": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:dev": "node ./scripts/build-package.mjs --mode=dev",
    "typecheck": "tsc --noEmit --project ./tsconfig.json",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "pack:check": "pnpm run build && pnpm pack --pack-destination .tmp/pack-check && node ./scripts/check-pack.mjs",
    "verify:dist-tracking": "node ./scripts/check-dist-tracking.mjs",
    "verify:core": "pnpm run typecheck && pnpm test && pnpm run pack:check && pnpm run verify:dist-tracking"
  },
  "dependencies": {
    "qrcode-terminal": "^0.12.0",
    "supports-hyperlinks": "3.2.0"
  },
  "devDependencies": {
    "@wecode/skill-qrcode-auth": "workspace:*",
    "@types/node": "^22.10.2",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
