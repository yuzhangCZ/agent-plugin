{
  "name": "@wecode/skill-qrcode-auth",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "package.json"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:dev": "node ./scripts/build-package.mjs --mode=dev && tsc --emitDeclarationOnly --project ./tsconfig.json && node ./scripts/rewrite-dts-imports.mjs",
    "typecheck": "tsc --noEmit --project ./tsconfig.json",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "pack:check": "pnpm run build && pnpm pack --pack-destination .tmp/pack-check && node ./scripts/check-pack.mjs",
    "verify:dist-tracking": "node ./scripts/check-dist-tracking.mjs",
    "verify:core": "pnpm run typecheck && pnpm test && pnpm run pack:check && pnpm run verify:dist-tracking",
    "prepublishOnly": "pnpm run build && pnpm run verify:core"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  }
}
