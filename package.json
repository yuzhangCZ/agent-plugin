{
  "name": "@opencode-cui/message-bridge",
  "version": "1.0.0",
  "description": "Message Bridge Plugin — unified message interface supporting OpenCode and future AI tools",
  "packageManager": "pnpm@9.15.4",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scripts/setup-message-bridge.mjs",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "pack:check": "rm -rf .tmp/pack-check && mkdir -p .tmp/pack-check && pnpm pack --pack-destination .tmp/pack-check",
    "prepublishOnly": "pnpm run build && pnpm run verify:core",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "node --import tsx/esm --test-isolation=none --test --test-force-exit tests/unit/*.test.mjs",
    "test:integration": "node --import tsx/esm --test-isolation=none --test tests/integration/*.test.mjs",
    "test:e2e": "node --import tsx/esm --test-isolation=none --test tests/e2e/*.test.mjs",
    "test:e2e:smoke": "node --import tsx/esm --test-isolation=none --test tests/e2e/connect-register.test.mjs tests/e2e/chat-stream.test.mjs tests/e2e/permission-roundtrip.test.mjs",
    "test:coverage": "node ./scripts/check-coverage.mjs",
    "smoke:e2e": "node ./scripts/e2e-smoke.mjs",
    "debug:e2e": "node ./scripts/debug-e2e.mjs",
    "logs:fetch": "node ./scripts/fetch-logs.mjs",
    "verify:core": "pnpm run typecheck && pnpm test && pnpm run test:coverage && pnpm run pack:check",
    "verify:env": "node ./scripts/verify-env.mjs",
    "verify:opencode-load": "node ./scripts/verify-opencode-load.mjs",
    "verify:release": "pnpm run verify:core && pnpm run verify:env && pnpm run test:e2e:smoke && pnpm run verify:opencode-load",
    "verify:release:dry": "pnpm run verify:release"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.2.15",
    "@opencode-ai/sdk": "1.2.15",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "c8": "^10.1.3",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "ws": "^8.18.0"
  }
}
