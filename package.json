{
  "name": "agent-plugin",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm run build:bridge && pnpm run build:openclaw",
    "build:bridge": "pnpm --dir plugins/message-bridge run build",
    "build:openclaw": "pnpm --dir plugins/message-bridge-openclaw run build",
    "build:openclaw:bundle": "pnpm --dir plugins/message-bridge-openclaw run build:bundle",
    "test": "pnpm run test:bridge && pnpm run test:openclaw",
    "test:bridge": "pnpm --dir plugins/message-bridge test",
    "test:openclaw": "pnpm --dir plugins/message-bridge-openclaw test",
    "verify:workspace": "pnpm run build && pnpm run test && pnpm run build:openclaw:bundle && pnpm run verify:test-boundaries",
    "verify:integration:fixture": "node ./scripts/verify-integration-fixture.mjs",
    "verify:test-boundaries": "node ./scripts/verify-test-boundaries.mjs",
    "test:openclaw:unit": "pnpm --dir plugins/message-bridge-openclaw run test:unit",
    "test:openclaw:integration": "pnpm --dir plugins/message-bridge-openclaw run test:integration",
    "test:openclaw:runtime": "pnpm --dir plugins/message-bridge-openclaw run test:runtime"
  }
}
