{
  "name": "agent-plugin",
  "private": true,
  "version": "0.0.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=9.15.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm run build:qrcode-auth && pnpm run build:skill-plugin-cli && pnpm run build:bridge && pnpm run build:openclaw",
    "build:qrcode-auth": "pnpm --dir packages/skill-qrcode-auth run build",
    "build:skill-plugin-cli": "pnpm --dir packages/skill-plugin-cli run build",
    "build:bridge": "pnpm --dir plugins/message-bridge run build",
    "build:openclaw": "pnpm --dir plugins/message-bridge-openclaw run build",
    "build:openclaw:bundle": "pnpm --dir plugins/message-bridge-openclaw run build:bundle",
    "release:local": "node ./scripts/release-local.mjs",
    "release:plan": "node ./scripts/release-local.mjs --dry-run",
    "verify:release-local:e2e": "node ./scripts/verify-release-local-e2e.mjs",
    "verify:qrcode-auth:core": "pnpm --dir packages/skill-qrcode-auth run verify:core",
    "verify:skill-plugin-cli:core": "pnpm --dir packages/skill-plugin-cli run verify:core",
    "verify:bridge:core": "pnpm --dir plugins/message-bridge run verify:core",
    "verify:openclaw:core": "pnpm --dir plugins/message-bridge-openclaw run verify:core",
    "test": "pnpm run test:test-support && pnpm run test:gateway-schema && pnpm run test:qrcode-auth && pnpm run test:skill-plugin-cli && pnpm run test:bridge && pnpm run test:openclaw && pnpm run test:release-local",
    "test:test-support": "pnpm --dir packages/test-support test",
    "test:gateway-schema": "pnpm --dir packages/gateway-schema test",
    "test:qrcode-auth": "pnpm --dir packages/skill-qrcode-auth test",
    "test:skill-plugin-cli": "pnpm --dir packages/skill-plugin-cli test",
    "test:bridge": "pnpm --dir plugins/message-bridge test",
    "test:openclaw": "pnpm --dir plugins/message-bridge-openclaw test",
    "test:release-local": "node --test ./scripts/release-local.test.mjs",
    "verify:workspace": "pnpm run build && pnpm run verify:qrcode-auth:core && pnpm run verify:skill-plugin-cli:core && pnpm run test && pnpm run build:openclaw:bundle && pnpm run verify:test-boundaries",
    "verify:integration:fixture": "node ./scripts/verify-integration-fixture.mjs",
    "verify:test-boundaries": "node ./scripts/verify-test-boundaries.mjs",
    "test:openclaw:unit": "pnpm --dir plugins/message-bridge-openclaw run test:unit",
    "test:openclaw:integration": "pnpm --dir plugins/message-bridge-openclaw run test:integration",
    "test:openclaw:runtime": "pnpm --dir plugins/message-bridge-openclaw run test:runtime",
    "verify:openclaw:env": "pnpm --dir plugins/message-bridge-openclaw run verify:openclaw:env",
    "verify:openclaw:load": "pnpm --dir plugins/message-bridge-openclaw run verify:openclaw:load"
  }
}
