{
  "name": "@opencode-cui/message-bridge",
  "version": "1.0.0",
  "description": "Message Bridge Plugin — unified message interface supporting OpenCode and future AI tools",
  "packageManager": "bun@1.3.10",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "test:e2e:smoke": "bun test tests/e2e/connect-register.test.mjs tests/e2e/chat-stream.test.mjs tests/e2e/permission-roundtrip.test.mjs",
    "test:coverage": "node ./scripts/check-coverage.mjs",
    "smoke:e2e": "node ./scripts/e2e-smoke.mjs",
    "verify:protocol-smoke": "node ./scripts/verify-protocol-smoke.mjs",
    "debug:e2e": "node ./scripts/debug-e2e.mjs",
    "logs:fetch": "node ./scripts/fetch-logs.mjs",
    "verify:opencode-load": "node ./scripts/verify-opencode-load.mjs"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.2.15",
    "@opencode-ai/sdk": "1.2.15",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
